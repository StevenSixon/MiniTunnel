# MiniTunnel environment configuration.
#
# Every command-line flag has a MINITUNNEL_* environment variable fallback.
# Precedence per setting is: explicit flag  >  environment variable  >  built-in default.
#
# Local use:
#   cp .env.example .env      # then edit, and:
#   set -a; source .env; set +a
#   ./bin/relay               # picks up the vars below, no flags needed
#
# Production: systemd reads this format via EnvironmentFile=, and the macOS
# LaunchDaemon embeds the same keys. The PSK must be IDENTICAL on all three.

# --- shared by all three programs ---
MINITUNNEL_PSK=change-me-to-a-long-random-secret   # e.g. openssl rand -hex 24
# MINITUNNEL_CERT / MINITUNNEL_KEY accept EITHER a file path OR inline PEM. To go
# file-free, paste the PEM directly (multi-line, double-quoted) — no .pem on disk:
#   MINITUNNEL_CERT="-----BEGIN CERTIFICATE-----
#   ...
#   -----END CERTIFICATE-----"
MINITUNNEL_CERT=cert.pem                            # pinned relay certificate (path or inline PEM)

# --- relay only ---
MINITUNNEL_ADDR=:7000                               # TLS listen address; BIND to an internal IP for an internal-only relay
MINITUNNEL_KEY=key.pem                              # relay private key (path or inline PEM) — relay host only
MINITUNNEL_HTTP_ADDR=                                # status dashboard + /healthz, e.g. :8080 (empty disables). Relay only.
MINITUNNEL_ADMIN_TOKEN=                              # gates the dashboard & /api/status; required to view them. /healthz stays open.

# --- agent only (office Mac mini) ---
MINITUNNEL_RELAY=relay.host:7000                    # where to dial the relay
MINITUNNEL_ID=office-mini                           # this agent's id
MINITUNNEL_ALLOW=22,5900                            # local ports a client may reach

# --- client only (your machine) ---
# MINITUNNEL_RELAY=relay.host:7000                  # same key as the agent uses
MINITUNNEL_AGENT=office-mini                        # target agent id
MINITUNNEL_FORWARD=2222:22,5901:5900               # comma-separated localPort:remotePort (or repeat -L)
