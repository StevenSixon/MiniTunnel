# Relay container environment — WebSocket / L7-gateway deployment ("scenario B").
#
# Use this when the relay is reachable only through a cloud platform's L7 HTTP(S)
# gateway (e.g. 云上 DevOps 平台 / APISIX), which terminates TLS with its own certificate and
# speaks HTTP. The tunnel rides a WebSocket on the relay's HTTP listener; the
# pinned relay TLS runs inside it, so the cert is still pinned end to end.
#
# Load these as the container's environment variables on the platform. Every
# MiniTunnel flag has a MINITUNNEL_* fallback, so no command-line args are needed.
# The agent and client then set:
#   MINITUNNEL_RELAY=wss://<your-domain><PREFIX>/tunnel   (e.g. .../api/tunnel)

# Shared secret — IDENTICAL on relay, agent and client. Generate:
#   openssl rand -hex 24
MINITUNNEL_PSK=change-me

# HTTP listener the gateway routes to. REQUIRED for the WebSocket tunnel: the
# relay serves the tunnel at <PREFIX>/tunnel, plus /healthz and the dashboard,
# on this port. Map the platform's service/route + container port to 8080, and
# make sure WebSocket upgrade is enabled on that route (APISIX: enable_websocket).
MINITUNNEL_HTTP_ADDR=:8080

# URL path prefix the gateway forwards to the container. If your route is
# /api/* -> container, set /api; the WS endpoint is then /api/tunnel, liveness
# /api/healthz, dashboard /api/. Leave empty if the gateway forwards from root.
MINITUNNEL_HTTP_PREFIX=/api

# Gates the dashboard + /api/status (NOT the tunnel). Required to view them.
# Pick the token you put after ?token= in the dashboard URL. Generate:
#   openssl rand -hex 16
MINITUNNEL_ADMIN_TOKEN=change-me-too

# Raw TLS listener. Unused when the relay is reached only via the L7 gateway,
# but the relay always starts it; harmless. Leave at the default.
MINITUNNEL_ADDR=:7000

# Relay certificate + key as SINGLE-LINE base64 PEM, so they live entirely in env
# with no .pem files in the image. Generate locally once:
#   go run ./cmd/gencert
#   base64 < cert.pem | tr -d '\n'    # paste as MINITUNNEL_CERT
#   base64 < key.pem  | tr -d '\n'    # paste as MINITUNNEL_KEY
# (loadPEM also accepts inline multi-line PEM, or a file path if you mount one.)
# The SAME cert.pem is what the agent and client pin via MINITUNNEL_CERT.
MINITUNNEL_CERT=
MINITUNNEL_KEY=
