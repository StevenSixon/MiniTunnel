# MiniTunnel agent container (Linux hosts).
#
# Build from the repo ROOT:
#   docker build -f deploy/Dockerfile.agent -t minitunnel-agent:latest .
#
# IMPORTANT — the agent bridges to 127.0.0.1:<port> in ITS OWN network namespace.
# To reach services on the host, run with host networking (Linux):
#   docker run -d --network host --env-file agent.env minitunnel-agent:latest
# Without it the agent only reaches services in the same container/pod (sidecar).
# On a Mac mini, Docker Desktop's host networking does NOT expose the mac host's
# loopback, so a containerized agent cannot reach the mini's sshd / Screen
# Sharing — install it on the mini as a LaunchDaemon instead (deploy/install-agent.sh).
#
# Config is entirely via MINITUNNEL_* env (see deploy/agent.env.example).

# ---- build ----
FROM golang:1.23-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/agent ./cmd/agent

# ---- runtime ----
# Unlike the relay, the agent dials OUT over wss:// and must verify the gateway's
# certificate against the system root CAs, so the image needs ca-certificates
# (a FROM scratch image has none). The inner pinned TLS uses MINITUNNEL_CERT and
# is independent of these roots.
FROM alpine:3.20
RUN apk add --no-cache ca-certificates \
 && adduser -S -D -H -u 65532 minitunnel
USER 65532
COPY --from=build /out/agent /agent
ENTRYPOINT ["/agent"]
