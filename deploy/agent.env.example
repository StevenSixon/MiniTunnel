# Agent container environment — for running the agent in a Linux container that
# connects to the relay over WebSocket (the wss / L7-gateway setup).
#
# For the office Mac mini, do NOT use a container: install the agent as a
# LaunchDaemon with deploy/install-agent.sh (a containerized agent on macOS
# cannot reach the mac host's sshd / Screen Sharing over 127.0.0.1).
#
# Run (Linux, host networking so 127.0.0.1 == the host's loopback):
#   docker run -d --name minitunnel-agent --network host \
#     --env-file agent.env minitunnel-agent:latest

# Shared secret — IDENTICAL to the relay and client.
MINITUNNEL_PSK=change-me

# Relay address. host:port for a direct/L4 dial, OR a ws://|wss:// URL to tunnel
# through an L7 HTTP gateway. The path is MINITUNNEL_HTTP_PREFIX + /tunnel.
MINITUNNEL_RELAY=wss://tunnel.example.com/api/tunnel

# This agent's id, chosen by you; the client targets it by this name.
MINITUNNEL_ID=office-mini

# Local ports a client may reach through this agent (the allowlist). These are
# ports on 127.0.0.1 in the agent's network namespace — with --network host that
# is the host's loopback. A client cannot make the agent reach anything else.
MINITUNNEL_ALLOW=22,5900

# Pinned relay certificate — the SAME cert.pem the relay presents. Single-line
# base64 PEM (file-free), inline PEM, or a mounted file path. Generate:
#   base64 < cert.pem | tr -d '\n'
MINITUNNEL_CERT=

# Only for a direct host:port dial through an L4 gateway that routes by TLS SNI.
# Leave empty for the wss:// transport (the URL host already routes).
# MINITUNNEL_SNI=tunnel.example.com
